<policies>
  <inbound>
    <base />
    <include-fragment fragment-id="provisioning-jwt" />
    <rewrite-uri template="@("/devices/" + (string)context.Variables["device-id"] + "/token")" />
    <set-backend-service backend-id="auth-backend" />
  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
