---
import { Zoom } from 'starlight-image-zoom/components';

interface Props {
  src: string;
  alt?: string;
  title?: string;
}

const { src, alt = "", title } = Astro.props;
const base = (import.meta.env.BASE_URL ?? "/").replace(/\/$/, "");
const resolvedSrc = src.startsWith("/") ? `${base}${src}` : src;
---

<Zoom label={alt}>
  <img src={resolvedSrc} alt={alt} title={title} />
</Zoom>
