<div class="value-flow-container">
  <div class="flow-step">
    <div class="step-icon">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>
    </div>
    <div class="step-content">
      <h3>IoT Devices</h3>
      <p>Secure hardware collects & transmits environmental data reliably.</p>
    </div>
  </div>

  <div class="flow-arrow">
    <div class="animated-packet" style="animation-delay: 0s;"></div>
    <svg viewBox="0 0 100 24" preserveAspectRatio="none"><path d="M0,12 L100,12" stroke="currentColor" stroke-dasharray="4,4" stroke-width="2" fill="none" /></svg>
  </div>

  <div class="flow-step">
    <div class="step-icon">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
    </div>
    <div class="step-content">
      <h3>Zero-Trust Cloud</h3>
      <p>Every payload securely verified before entering the system.</p>
    </div>
  </div>

  <div class="flow-arrow">
    <div class="animated-packet" style="animation-delay: 1s;"></div>
    <svg viewBox="0 0 100 24" preserveAspectRatio="none"><path d="M0,12 L100,12" stroke="currentColor" stroke-dasharray="4,4" stroke-width="2" fill="none" /></svg>
  </div>

  <div class="flow-step">
    <div class="step-icon">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.58 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.58 4 8 4s8-1.79 8-4M4 7c0-2.21 3.58-4 8-4s8 1.79 8 4m0 5c0 2.21-3.58 4-8 4s-8-1.79-8-4" /></svg>
    </div>
    <div class="step-content">
      <h3>NoSQL Database</h3>
      <p>Seamlessly scales from zero to handle massive surges in telemetry data effortlessly.</p>
    </div>
  </div>

  <div class="flow-arrow">
    <div class="animated-packet" style="animation-delay: 2s;"></div>
    <svg viewBox="0 0 100 24" preserveAspectRatio="none"><path d="M0,12 L100,12" stroke="currentColor" stroke-dasharray="4,4" stroke-width="2" fill="none" /></svg>
  </div>

  <div class="flow-step">
    <div class="step-icon">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
    </div>
    <div class="step-content">
      <h3>Global Dashboard</h3>
      <p>Real-time telemetry and analytics anywhere via blazing-fast client.</p>
    </div>
  </div>
</div>

<style>
  .value-flow-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 2rem 0;
    gap: 0.5rem;
  }

  .flow-step {
    flex: 1;
    min-width: 0;
    text-align: center;
    position: relative;
    padding: 1.5rem 1rem;
    background: var(--sl-color-bg);
    border-radius: 0.75rem;
    border: 1px solid var(--sl-color-hairline-shade, var(--sl-color-hairline));
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .flow-step:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    border-color: var(--sl-color-accent);
  }

  .step-icon {
    width: 3.5rem;
    height: 3.5rem;
    margin: 0 auto 1rem;
    color: var(--sl-color-accent);
    background: var(--sl-color-accent-low);
    border-radius: 50%;
    padding: 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .step-content h3 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--sl-color-text);
    letter-spacing: -0.01em;
  }

  .step-content p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    line-height: 1.5;
  }

  .flow-arrow {
    flex: 0 0 40px;
    height: 24px;
    position: relative;
    color: var(--sl-color-gray-5);
  }

  .flow-arrow svg {
    width: 100%;
    height: 100%;
  }

  .animated-packet {
    position: absolute;
    top: 50%;
    left: 0;
    width: 6px;
    height: 6px;
    background: var(--sl-color-accent);
    border-radius: 50%;
    transform: translateY(-50%);
    box-shadow: 0 0 8px var(--sl-color-accent);
    animation: movePacket 3s infinite linear;
    z-index: 10;
  }

  @keyframes movePacket {
    0% { transform: translate(0, -50%); opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 1; }
    100% { transform: translate(var(--flow-dist, 40px), -50%); opacity: 0; }
  }

  @media (max-width: 900px) {
    .value-flow-container {
      flex-direction: column;
      gap: 0;
    }
    .flow-arrow {
      --flow-dist: 24px;
      width: 24px;
      height: 40px;
      transform: rotate(90deg);
      margin: 1rem 0;
    }
    .flow-step {
      width: 100%;
      max-width: 320px;
    }
  }
</style>
