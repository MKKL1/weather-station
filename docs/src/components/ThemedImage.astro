---
import { Zoom } from 'starlight-image-zoom/components';

interface Props {
  light: string;
  dark: string;
  alt?: string;
}

const { light, dark, alt = "" } = Astro.props;
const base = (import.meta.env.BASE_URL ?? "/").replace(/\/$/, "");
const resolve = (src: string) => (src.startsWith("/") ? `${base}${src}` : src);
---

<div class="themed-image">
  <Zoom label={alt}>
    <img src={resolve(light)} alt={alt} class="dark:sl-hidden" loading="lazy" decoding="async" />
  </Zoom>
  <Zoom label={alt}>
    <img src={resolve(dark)} alt={alt} class="light:sl-hidden" loading="lazy" decoding="async" />
  </Zoom>
</div>
